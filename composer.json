{
    "name": "noizu-labs/fragmented-keys",
    "description": "Fragmented key cache invalidation library. Compose cache keys from independently versioned tags — increment a tag to invalidate all dependent keys without explicit deletes.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "cache",
        "invalidation",
        "fragmented-keys",
        "cache-keys",
        "tags",
        "memcached",
        "redis"
    ],
    "authors": [
        {
            "name": "Keith Brings",
            "email": "keith.brings@noizu.com"
        }
    ],
    "homepage": "https://github.com/noizu-labs/fragmented-keys",
    "require": {
        "php": "^8.4",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "php-cs-fixer/shim": "^3.0"
    },
    "suggest": {
        "ext-redis": "Required for RedisHandler",
        "ext-memcached": "Required for MemcachedHandler",
        "ext-apcu": "Required for APCuHandler"
    },
    "autoload": {
        "psr-4": {
            "NoizuLabs\\FragmentedKeys\\": "src/FragmentedKeys/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NoizuLabs\\FragmentedKeys\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "coverage": "XDEBUG_MODE=coverage phpunit --coverage-text --coverage-html coverage/html --coverage-clover coverage/clover.xml",
        "analyse": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
